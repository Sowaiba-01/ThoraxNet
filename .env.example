# ── Required ──────────────────────────────────────────────────────────────────
# One of these two is required to load the model:
MODEL_HUB_REPO=yourusername/chestai-model   # HuggingFace Hub repo ID
MODEL_CHECKPOINT=                            # OR local path to .pt file

# Groq API (free at console.groq.com — no credit card)
GROQ_API_KEY=gsk_...

# ── Optional ─────────────────────────────────────────────────────────────────
# W&B (for training only)
WANDB_API_KEY=

# HuggingFace (for model upload + Spaces deploy)
HF_TOKEN=hf_...

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:7860
